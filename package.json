{
  "name": "html-basico",
  "version": "1.0.2",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dist": "electron-builder --mac",
    "dist:dmg": "electron-builder --mac dmg",
    "dist:zip": "electron-builder --mac zip",
    "dist:win": "electron-builder --win"
  },
  "keywords": [],
  "author": "Nexora Vision Pro",
  "license": "ISC",
  "description": "CorePoint App",
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.nexoravisionpro.corepoint",
    "productName": "CorePoint",
    "publish": [
      {
        "provider": "github",
        "owner": "nexoravisionpro",
        "repo": "app-electron"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9"
  }
}
